PORT=4000
MONGODB_STRING=
SECRET=
CLIENT_URL=http://localhost:5173

# Set to "production" on deploy so the auth cookie is sent Secure (HTTPS only).
NODE_ENV=development

# Optional: Cloudinary image uploads for admin product photos.
# Leave unset to fall back to pasting an image URL.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=aster-products
